@model StudentApp.Models.Attendance
@{ ViewData["Title"] = "Detaylar"; }
<h1>Detaylar</h1>
<div>
    <h4>Devamsızlık Kaydı</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">Tarih</dt>
        <dd class = "col-sm-10">@Model.Date.ToString("dd.MM.yyyy HH:mm")</dd>
        <dt class = "col-sm-2">Durum</dt>
        <dd class = "col-sm-10">@Model.Status</dd>
        <dt class = "col-sm-2">Öğrenci Adı</dt>
        <dd class = "col-sm-10">@Html.DisplayFor(model => model.Student.FullName)</dd>
        <dt class = "col-sm-2">Veli E-Posta</dt> @* DÜZELTİLDİ *@
        <dd class = "col-sm-10">@Html.DisplayFor(model => model.Student.ParentEmail)</dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning">Düzenle</a> |
    <a asp-action="Index" class="btn btn-secondary">Listeye Dön</a>
</div>
@model IEnumerable<StudentApp.Models.Intervention>

@{
    ViewData["Title"] = "Incidents";
}

<h1>Incident Response Log</h1>

<table class="table table-hover table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Timestamp</th>
            <th>Student</th>
            <th>Type</th>
            <th>Details</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>@item.Date.ToString("dd.MM.yyyy HH:mm")</td>
            <td>
                @(item.Student != null
                    ? $"{item.Student.FullName} (ID: {item.Student.Id})"
                    : "Unknown Student")
            </td>
            <td>@item.Type</td>
            <td style="white-space: pre-line;">
                @item.Notes
            </td>
        </tr>
}
    </tbody>
</table>
